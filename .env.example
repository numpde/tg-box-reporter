# Collector
COLLECTOR_BIND_HOST=127.0.0.1
COLLECTOR_PORT=9707
COLLECTOR_CACHE_SECONDS=5
COLLECTOR_HOST_PROC=/proc
COLLECTOR_HOST_ROOT=/
COLLECTOR_DISK_PATH=/
COLLECTOR_DOCKER_BIN=docker
COLLECTOR_INCLUDE_STOPPED=1
COLLECTOR_NAME_INCLUDE_REGEX=
COLLECTOR_NAME_EXCLUDE_REGEX=
COLLECTOR_REQUIRE_DOCKER=0
COLLECTOR_ALERT_LOAD_PER_CPU_GT=1.5
COLLECTOR_ALERT_MEM_PERCENT_GT=90
COLLECTOR_ALERT_SWAP_USED_MB_GT=256
COLLECTOR_ALERT_DISK_PERCENT_GT=90
COLLECTOR_ALERT_CONTAINER_RESTART_COUNT_GT=5
COLLECTOR_ALERT_CONTAINER_CPU_PERCENT_GT=85
COLLECTOR_ALERT_CONTAINER_MEM_PERCENT_GT=85
COLLECTOR_DOCKER_TIMEOUT_SECONDS=10
COLLECTOR_EVENT_TOKEN=
COLLECTOR_EVENT_MAX_RECENT=200
COLLECTOR_EVENT_RETENTION_SECONDS=3600
COLLECTOR_EVENT_MAX_BYTES=16384
COLLECTOR_ALERTS_ENABLED=0
COLLECTOR_ALERT_MAX_RECENT=200
COLLECTOR_ALERT_RETENTION_SECONDS=86400
COLLECTOR_ALERT_ROUTE_ERROR_RATE_HIGH_ENABLED=0
COLLECTOR_ALERT_ROUTE_ERROR_RATE_HIGH_ALLOWLIST_REGEX=
COLLECTOR_ALERT_ROUTE_ERROR_RATE_HIGH_WINDOW_SECONDS=300
COLLECTOR_ALERT_ROUTE_ERROR_RATE_HIGH_MIN_REQUESTS=10
COLLECTOR_ALERT_ROUTE_ERROR_RATE_HIGH_MIN_ERRORS=5
COLLECTOR_ALERT_ROUTE_ERROR_RATE_HIGH_ERROR_RATE_GT=0.5
COLLECTOR_ALERT_ROUTE_ERROR_RATE_HIGH_CLEAR_RATE_LT=0.2
COLLECTOR_ALERT_ROUTE_ERROR_RATE_HIGH_STATUS_CLASSES=5xx
COLLECTOR_ALERT_ROUTE_SEEN_AFTER_QUIET_ENABLED=0
COLLECTOR_ALERT_ROUTE_SEEN_AFTER_QUIET_ALLOWLIST_REGEX=
COLLECTOR_ALERT_ROUTE_SEEN_AFTER_QUIET_PERIOD_SECONDS=21600
COLLECTOR_ALERT_ROUTE_SEEN_AFTER_QUIET_EMIT_ON_FIRST_SEEN=0
COLLECTOR_SHARED_NETWORK=
COLLECTOR_SHARED_ALIAS=tg-box-collector

# Relay
TG_BOT_TOKEN=
TG_CHAT_ID=
TG_ALLOWED_CHAT_IDS=
TG_API_BASE=https://api.telegram.org
COLLECTOR_URL=http://127.0.0.1:9707/snapshot
RELAY_MODE=hybrid
RELAY_INTERVAL_SECONDS=900
RELAY_STARTUP_REPORT=0
RELAY_REQUEST_TIMEOUT_SECONDS=20
TG_GET_UPDATES_TIMEOUT_SECONDS=30
REPORT_MAX_CONTAINERS=10
RELAY_HEARTBEAT_PATH=/tmp/tg-box-reporter-relay.heartbeat
RELAY_HEALTH_STALE_SECONDS=120
RELAY_ALERTS_ENABLED=0
RELAY_ALERT_POLL_SECONDS=15
RELAY_ALERT_BATCH_SIZE=20
