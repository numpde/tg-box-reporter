[Unit]
Description=Telegram Box Reporter Relay
After=network-online.target tg-box-collector.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/tg-box-reporter
EnvironmentFile=-/etc/tg-box-reporter/relay.env
ExecStart=/usr/bin/env python3 -m tg_box_reporter.relay
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6

[Install]
WantedBy=multi-user.target
